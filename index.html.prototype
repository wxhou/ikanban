/* ═══════════════════════════════════════════
   FILTER BAR
═══════════════════════════════════════════ */
const FILTER_TABS = [
  { id: "all", label: "全部" },
  { id: "jiafang", label: "甲方任务" },
  { id: "internal", label: "内部任务" },
  { id: "mine", label: "只看我的" },
];

function FilterBar({ filter, onFilterChange, taskCount, filteredCount, search, onSearchChange }) {
  return (
    <div className="filter-bar">
      <div className="filter-pills">
        {FILTER_TABS.map(tab => (
          <button key={tab.id} className={`filter-pill${filter === tab.id ? " active" : ""}`} onClick={() => onFilterChange(tab.id)}>
            {tab.label}
          </button>
        ))}
      </div>
      <div className="filter-spacer" />
      <div className="search-wrap">
        <span className="search-icon"><IconSearch /></span>
        <input
          className="search-input"
          placeholder="搜索任务…"
          value={search}
          onChange={e => onSearchChange(e.target.value)}
        />
        {search && (
          <span className="search-clear" onClick={() => onSearchChange("")}>
            <svg viewBox="0 0 10 10" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round"><path d="M2 2l6 6M8 2l-6 6"/></svg>
          </span>
        )}
      </div>
      <span className="filter-count">
        {filteredCount === taskCount ? `${taskCount} 个任务` : `${filteredCount} / ${taskCount} 个任务`}
      </span>
    </div>
  );
}

/* ═══════════════════════════════════════════
   TASK CARD
═══════════════════════════════════════════ */
function TaskCard({ task, columnStatus, onEdit, onDragStart, onDragEnd, onDragOver, onDrop }) {
  const priorityColor = { high: "var(--danger)", medium: "var(--warn)", low: "var(--success)" };
  const sourceLabel = { jiafang: "甲方", internal: "内部" };
  return (
    <div
      className="task-card"
      draggable
      onDragStart={e => { e.dataTransfer.setData("taskId", String(task.id)); onDragStart(task.id); }}
      onDragEnd={onDragEnd}
      onDragOver={e => { e.preventDefault(); onDragOver(task.id); }}
      onDrop={e => { e.preventDefault(); e.stopPropagation(); onDrop(columnStatus); }}
      onDoubleClick={() => onEdit(task)}
    >
      <div className="card-top">
        <span className="priority-dot" style={{ background: priorityColor[task.priority] }} />
        <span className="card-title">{task.title}</span>
      </div>
      {task.desc && <div className="card-body"><div className="card-desc">{task.desc}</div></div>}
      <div className="card-tags">
        <span className={`tag tag-${task.source}`}>{sourceLabel[task.source]}</span>
        {task.requester && <span className="tag tag-requester">{task.requester}</span>}
      </div>
      <div className="card-footer">
        <div className="card-meta">
          <span className="card-meta-item"><IconCalendar /> {formatDate(task.due)}</span>
        </div>
        <div style={{ display: "flex", marginLeft: "auto" }}>
          {task.assignees.slice(0, 3).map((a, i) => (
            <div key={i} className="card-assignee" style={{ background: getAssigneeColor(a), marginLeft: i > 0 ? "-6px" : 0, zIndex: 10 - i }}>
              {getInitials(a)}
            </div>
          ))}
          {task.assignees.length > 3 && (
            <div className="card-assignee" style={{ background: "var(--muted)", marginLeft: "-6px" }}>+{task.assignees.length - 3}</div>
          )}
        </div>
      </div>
    </div>
  );
}

/* ═══════════════════════════════════════════
   KANBAN COLUMN
═══════════════════════════════════════════ */
function KanbanColumn({ col, tasks, onAddTask, onEditTask, onDragStart, onDragEnd, onDragOver, onDrop, dragOverId, dragId }) {
  return (
    <div className={`kcol${dragOverId && dragId && dragId !== dragOverId ? " drop-target" : ""}`}>
      <div className="kcol-head">
        <span className={`kcol-dot dot-${col.id}`} />
        <span className="kcol-title">{col.label}</span>
        <span className="kcol-count">{tasks.length}</span>
      </div>
      <div className="kcol-body"
        onDragOver={e => e.preventDefault()}
        onDrop={e => { e.preventDefault(); e.stopPropagation(); onDrop(col.id); }}
      >
        {tasks.length === 0 ? (
          <div className="kcol-empty">
            <svg className="kcol-empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <path d="M12 8v8M8 12h8"/>
            </svg>
            暂无任务
          </div>
        ) : tasks.map(task => (
          <TaskCard
            key={task.id}
            task={task}
            columnStatus={col.id}
            onEdit={onEditTask}
            onDragStart={onDragStart}
            onDragEnd={onDragEnd}
            onDragOver={onDragOver}
            onDrop={onDrop}
            dragOverId={dragOverId}
          />
        ))}
      </div>
      <div className="kcol-footer">
        <button className="add-card-btn" onClick={() => onAddTask(col.id)}>
          <IconPlus /> 添加任务
        </button>
      </div>
    </div>
  );
}

/* ═══════════════════════════════════════════
   KANBAN BOARD
═══════════════════════════════════════════ */
function KanbanBoard({ tasks, setTasks, onEditTask }) {
  const [filter, setFilter] = useState("all");
  const [search, setSearch] = useState("");
  const [dragId, setDragId] = useState(null);
  const [dragOverId, setDragOverId] = useState(null);

  const filtered = useMemo(() => {
    return tasks.filter(t => {
      if (filter === "jiafang") return t.source === "jiafang";
      if (filter === "internal") return t.source === "internal";
      if (filter === "mine") return t.assignees.includes("张三");
      return true;
    }).filter(t => {
      if (!search.trim()) return true;
      const q = search.toLowerCase();
      return t.title.toLowerCase().includes(q) || (t.desc && t.desc.toLowerCase().includes(q)) || (t.requester && t.requester.includes(q));
    });
  }, [tasks, filter, search]);

  const tasksByStatus = useMemo(() => {
    const map = {};
    COLUMNS.forEach(c => { map[c.id] = filtered.filter(t => t.status === c.id); });
    return map;
  }, [filtered]);

  const handleDragStart = useCallback((id) => setDragId(id), []);
  const handleDragEnd = useCallback(() => { setDragId(null); setDragOverId(null); }, []);
  const handleDragOver = useCallback((id) => setDragOverId(id), []);
  const handleDrop = useCallback((targetStatus) => {
    if (!dragId) return;
    setTasks(prev => prev.map(t => t.id === dragId ? { ...t, status: targetStatus } : t));
    setDragId(null); setDragOverId(null);
  }, [dragId, setTasks]);

  return (
    <div style={{ display: "flex", flexDirection: "column", flex: 1, overflow: "hidden" }}>
      <FilterBar filter={filter} onFilterChange={setFilter} taskCount={tasks.length} filteredCount={filtered.length} search={search} onSearchChange={setSearch} />
      <div className="kanban-wrap">
        <div className="kanban-board">
          {COLUMNS.map(col => (
            <KanbanColumn
              key={col.id}
              col={col}
              tasks={tasksByStatus[col.id]}
              onAddTask={(status) => onEditTask({ id: null, status })}
              onEditTask={onEditTask}
              onDragStart={handleDragStart}
              onDragEnd={handleDragEnd}
              onDragOver={handleDragOver}
              onDrop={handleDrop}
              dragOverId={dragOverId}
              dragId={dragId}
            />
          ))}
        </div>
      </div>
    </div>
  );
}

/* ═══════════════════════════════════════════
   TASK MODAL
═══════════════════════════════════════════ */
function TaskModal({ task, columns, teamMembers, jiafangSources, onSave, onClose }) {
  const isNew = !task.id;
  const [form, setForm] = useState({
    title: task.title || "",
    desc: task.desc || "",
    status: task.status || "todo",
    priority: task.priority || "medium",
    source: task.source || "internal",
    requester: task.requester || "",
    assignees: task.assignees || [],
    due: task.due || "",
  });

  const set = (k, v) => setForm(f => ({ ...f, [k]: v }));
  const toggleAssignee = (name) => {
    setForm(f => ({
      ...f,
      assignees: f.assignees.includes(name) ? f.assignees.filter(a => a !== name) : [...f.assignees, name]
    }));
  };
  const handleSave = () => {
    if (!form.title.trim()) return;
    onSave({ ...task, ...form });
  };
  return (
    <div className="modal-overlay" onClick={e => e.target === e.currentTarget && onClose()}>
      <div className="modal">
        <div className="modal-head">
          <h2 className="modal-title">{isNew ? "新建任务" : "编辑任务"}</h2>
          <button className="modal-close" onClick={onClose}><IconX /></button>
        </div>
        <div className="modal-body">
          <div className="form-row">
            <label className="form-label">任务标题 *</label>
            <input className="form-input" placeholder="简要描述任务内容" value={form.title} onChange={e => set("title", e.target.value)} autoFocus />
          </div>
          <div className="form-row">
            <label className="form-label">详细描述</label>
            <textarea className="form-input" placeholder="补充背景、要求、注意事项…" value={form.desc} onChange={e => set("desc", e.target.value)} />
          </div>
          <div className="form-row-inline">
            <div className="form-row">
              <label className="form-label">状态</label>
              <select className="form-input" value={form.status} onChange={e => set("status", e.target.value)}>
                {columns.map(c => <option key={c.id} value={c.id}>{c.label}</option>)}
              </select>
            </div>
            <div className="form-row">
              <label className="form-label">优先级</label>
              <select className="form-input" value={form.priority} onChange={e => set("priority", e.target.value)}>
                <option value="high">高</option>
                <option value="medium">中</option>
                <option value="low">低</option>
              </select>
            </div>
          </div>
          <div className="form-row">
            <label className="form-label">任务来源</label>
            <div className="tag-select">
              {[{ id: "jiafang", label: "甲方任务" }, { id: "internal", label: "内部任务" }].map(opt => (
                <button key={opt.id} type="button"
                  className={`tag-option${form.source === opt.id ? " selected" : ""}`}
                  onClick={() => set("source", opt.id)}>
                  {opt.label}
                </button>
              ))}
            </div>
          </div>
          {form.source === "jiafang" && (
            <div className="form-row">
              <label className="form-label">甲方对接人</label>
              <div className="tag-select">
                {jiafangSources.map(src => (
                  <button key={src} type="button"
                    className={`tag-option${form.requester === src ? " selected" : ""}`}
                    onClick={() => set("requester", form.requester === src ? "" : src)}>
                    {src}
                  </button>
                ))}
              </div>
            </div>
          )}
          <div className="form-row">
            <label className="form-label">负责人 <span style={{ fontWeight: 400, color: "var(--muted)" }}>（可多选）</span></label>
            <div className="assignee-grid">
              {teamMembers.map(name => (
                <button key={name} type="button"
                  className={`assignee-chip${form.assignees.includes(name) ? " selected" : ""}`}
                  onClick={() => toggleAssignee(name)}>
                  <div style={{ width: 16, height: 16, borderRadius: "50%", background: getAssigneeColor(name), display: "flex", alignItems: "center", justifyContent: "center", fontSize: 9, color: "white", fontWeight: 700 }}>{getInitials(name)}</div>
                  {name}
                </button>
              ))}
            </div>
          </div>
          <div className="form-row">
            <label className="form-label">截止日期</label>
            <input className="form-input" type="date" value={form.due} onChange={e => set("due", e.target.value)} />
          </div>
        </div>
        <div className="modal-foot">
          <button className="btn btn-secondary" onClick={onClose}>取消</button>
          <button className="btn btn-primary" onClick={handleSave}>{isNew ? "创建任务" : "保存修改"}</button>
        </div>
      </div>
    </div>
  );
}

/* ═══════════════════════════════════════════
   DASHBOARD
═══════════════════════════════════════════ */
function Dashboard({ tasks }) {
  const total = tasks.length;
  const done = tasks.filter(t => t.status === "done").length;
  const inprogress = tasks.filter(t => t.status === "inprogress").length;
  const blocked = tasks.filter(t => t.status === "blocked").length;
  const jiafang = tasks.filter(t => t.source === "jiafang").length;
  const jiafangDone = tasks.filter(t => t.source === "jiafang" && t.status === "done").length;
  const internal = tasks.filter(t => t.source === "internal").length;
  const internalDone = tasks.filter(t => t.source === "internal" && t.status === "done").length;
  const completion = total > 0 ? Math.round(done / total * 100) : 0;
  const jiafangPct = jiafang > 0 ? Math.round(jiafangDone / jiafang * 100) : 0;
  const internalPct = internal > 0 ? Math.round(internalDone / internal * 100) : 0;
  const statusMap = { todo:"待办", inprogress:"进行中", review:"审核中", blocked:"已阻塞", done:"已完成" };
  const priorityMap = { high:"高", medium:"中", low:"低" };
  const sourceMap = { jiafang:"甲方", internal:"内部" };
  return (
    <div className="dashboard">
      <div className="db-header">
        <div>
          <h1 className="db-title">项目全局概览</h1>
          <p className="db-sub">智慧城市平台 v2.0 · 数据更新于 {new Date().toLocaleDateString("zh-CN")}</p>
        </div>
      </div>

      <div className="db-stats">
        <div className="stat-card">
          <div className="stat-label">总任务数</div>
          <div className="stat-value">{total}</div>
          <div className="stat-change neutral">全部任务</div>
        </div>
        <div className="stat-card">
          <div className="stat-label">完成率</div>
          <div className="stat-value">{completion}<span style={{ fontSize: "var(--text-xl)", fontWeight: 500 }}>%</span></div>
          <div className="stat-change up">已完成 {done} 项任务</div>
        </div>
        <div className="stat-card">
          <div className="stat-label">进行中</div>
          <div className="stat-value">{inprogress}</div>
          <div className="stat-change neutral">项任务推进中</div>
        </div>
        <div className="stat-card">
          <div className="stat-label">已阻塞</div>
          <div className="stat-value">{blocked}</div>
          <div className={blocked > 0 ? "stat-change warn" : "stat-change neutral"}>{blocked > 0 ? `需关注 ${blocked} 项阻塞` : "无阻塞项"}</div>
        </div>
      </div>

      <div className="db-grid">
        <div className="db-section">
          <div className="db-sec-head">
            <span className="db-sec-title">任务清单</span>
            <span style={{ fontSize: "var(--text-xs)", color: "var(--muted)" }}>{total} 个任务</span>
          </div>
          <div className="db-sec-body" style={{ maxHeight: 480, overflowY: "auto" }}>
            <table className="task-table">
              <thead>
                <tr>
                  <th>任务</th>
                  <th>状态</th>
                  <th>优先级</th>
                  <th>来源</th>
                  <th>负责人</th>
                  <th>截止</th>
                </tr>
              </thead>
              <tbody>
                {tasks.map(t => (
                  <tr key={t.id}>
                    <td className="td-title">
                      <div className="td-title-inner">{t.title}</div>
                    </td>
                    <td>
                      <span className="status-dot" style={{ background: { todo: "var(--meta)", inprogress: "var(--accent)", review: "var(--warn)", blocked: "var(--danger)", done: "var(--success)" }[t.status] }} />
                      {statusMap[t.status]}
                    </td>
                    <td><span className={`priority-badge pb-${t.priority}`}>{priorityMap[t.priority]}</span></td>
                    <td><span className={`source-badge sb-${t.source}`}>{sourceMap[t.source]}{t.requester ? ` · ${t.requester}` : ""}</span></td>
                    <td>
                      <div style={{ display: "flex" }}>
                        {t.assignees.slice(0, 2).map((a, i) => (
                          <div key={i} className="assignee-mini" style={{ background: getAssigneeColor(a), marginLeft: i > 0 ? "-5px" : 0 }} title={a}>{getInitials(a)}</div>
                        ))}
                      </div>
                    </td>
                    <td style={{ color: "var(--muted)", fontSize: "var(--text-xs)" }}>{formatDate(t.due)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <div style={{ display: "flex", flexDirection: "column", gap: "var(--space-5)" }}>
          <div className="db-section">
            <div className="db-sec-head">
              <span className="db-sec-title">完成进度</span>
            </div>
            <div style={{ padding: "var(--space-5)" }}>
              <div className="progress-row">
                <span className="progress-label">甲方任务</span>
                <div className="progress-track"><div className="progress-fill" style={{ width: `${jiafangPct}%`, background: "var(--accent)" }} /></div>
                <span className="progress-pct">{jiafangPct}%</span>
              </div>
              <div className="progress-row">
                <span className="progress-label">内部任务</span>
                <div className="progress-track"><div className="progress-fill" style={{ width: `${internalPct}%`, background: "var(--success)" }} /></div>
                <span className="progress-pct">{internalPct}%</span>
              </div>
              <div style={{ fontSize: "var(--text-xs)", color: "var(--muted)", marginTop: "var(--space-2)" }}>
                甲方 {jiafangDone}/{jiafang} · 内部 {internalDone}/{internal}
              </div>
            </div>
          </div>

          <div className="db-section">
            <div className="db-sec-head">
              <span className="db-sec-title">导出汇报</span>
            </div>
            <div className="export-bar">
              <div style={{ display: "flex", alignItems: "center", gap: "var(--space-3)", marginBottom: "var(--space-2)" }}>
                <div style={{ width: 40, height: 40, background: "var(--success-bg)", borderRadius: "var(--radius-sm)", display: "flex", alignItems: "center", justifyContent: "center" }}>
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="var(--success)" strokeWidth="1.8" strokeLinecap="round" strokeLinejoin="round"><path d="M10 2v11M5 8l5 5 5-5M3 16v2h14v-2"/></svg>
                </div>
                <div>
                  <div style={{ fontSize: "var(--text-sm)", fontWeight: 600 }}>Excel / CSV 导出</div>
                  <div style={{ fontSize: "var(--text-xs)", color: "var(--muted)" }}>适合发给老板的列表格式</div>
                </div>
              </div>
              <p className="export-desc">导出当前所有任务的完整列表，包含状态、优先级、来源、负责人、截止日期等信息，可直接用 Excel 打开。</p>
              <button className="export-btn" onClick={() => exportToExcel(tasks)}>
                <IconDownload /> 导出 CSV 文件
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}

/* ═══════════════════════════════════════════
   APP ROOT
═══════════════════════════════════════════ */
function App() {
  const [tasks, setTasks] = useState(INITIAL_TASKS);
  const [view, setView] = useState("kanban");
  const [modalTask, setModalTask] = useState(null);

  const handleSaveTask = useCallback((saved) => {
    setTasks(prev => {
      const exists = prev.find(t => t.id === saved.id);
      if (exists) return prev.map(t => t.id === saved.id ? saved : t);
      return [...prev, { ...saved, id: Date.now(), created: new Date().toISOString().slice(0,10) }];
    });
    setModalTask(null);
  }, []);

  return (
    <div className="app">
      <TopNav view={view} onViewChange={setView} />
      {view === "kanban" ? (
        <KanbanBoard tasks={tasks} setTasks={setTasks} onEditTask={setModalTask} />
      ) : (
        <Dashboard tasks={tasks} />
      )}
      {modalTask !== null && (
        <TaskModal
          task={modalTask}
          columns={COLUMNS}
          teamMembers={TEAM_MEMBERS}
          jiafangSources={JIAFANG_SOURCES}
          onSave={handleSaveTask}
          onClose={() => setModalTask(null)}
        />
      )}
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App />);
</script>
</body>
</html>
