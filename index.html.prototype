
<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>项目看板 — 全局管理</title>
  <script src="https://unpkg.com/react@18.3.1/umd/react.development.js" integrity="sha384-hD6/rw4ppMLGNu3tX5cjIb+uRZ7UkRJ6BPkLpg4hAu/6onKUg4lLsHAs9EBPT82L" crossorigin="anonymous"></script>
  <script src="https://unpkg.com/react-dom@18.3.1/umd/react-dom.development.js" integrity="sha384-u6aeetuaXnQ38mYT8rp6sbXaQe3NL9t+IBXmnYxwkUI2Hw4bsp2Wvmx4yRQF1uAm" crossorigin="anonymous"></script>
  <script src="https://unpkg.com/@babel/standalone@7.29.0/babel.min.js" integrity="sha384-m08KidiNqLdpJqLq95G/LEi8Qvjl/xUYll3QILypMoQ65QorJ9Lvtp2RXYGBFj1y" crossorigin="anonymous"></script>
  <style>
    :root {
      --bg: #fafafa;
      --surface: #ffffff;
      --fg: #111111;
      --fg-2: #333333;
      --muted: #6b6b6b;
      --meta: #9a9a9a;
      --border: #e5e5e5;
      --border-soft: #f0f0f0;
      --accent: #2f6feb;
      --accent-on: #ffffff;
      --accent-hover: #1a5ad8;
      --accent-active: #1440a8;
      --success: #17a34a;
      --success-bg: #dcfce7;
      --warn: #eab308;
      --warn-bg: #fef9c3;
      --danger: #dc2626;
      --danger-bg: #fee2e2;
      --surface-warm: #f8f8f8;
      --font-display: "Inter", -apple-system, system-ui, sans-serif;
      --font-body: "Inter", -apple-system, system-ui, sans-serif;
      --font-mono: ui-monospace, "JetBrains Mono", monospace;
      --text-xs: 12px;
      --text-sm: 14px;
      --text-base: 16px;
      --text-lg: 20px;
      --text-xl: 24px;
      --text-2xl: 32px;
      --text-3xl: 48px;
      --leading-body: 1.5;
      --leading-tight: 1.2;
      --tracking-display: -0.01em;
      --space-1: 4px;
      --space-2: 8px;
      --space-3: 12px;
      --space-4: 16px;
      --space-5: 20px;
      --space-6: 24px;
      --space-8: 32px;
      --space-12: 48px;
      --radius-sm: 8px;
      --radius-md: 12px;
      --radius-lg: 16px;
      --elev-raised: 0 2px 8px color-mix(in oklab, var(--fg), transparent 92%);
      --motion-fast: 150ms;
      --motion-base: 200ms;
      --ease-standard: cubic-bezier(0.2, 0, 0, 1);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { font-family: var(--font-body); font-size: var(--text-base); color: var(--fg); background: var(--bg); line-height: var(--leading-body); -webkit-font-smoothing: antialiased; }
    button { font-family: inherit; cursor: pointer; border: none; background: none; }
    input, textarea, select { font-family: inherit; font-size: inherit; }
    a { color: var(--accent); text-decoration: none; }
    ::-webkit-scrollbar { width: 4px; height: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: transparent; border-radius: 999px; transition: background 0.2s; }
    :hover::-webkit-scrollbar-thumb { background: var(--border); }
    ::-webkit-scrollbar-thumb:hover { background: var(--muted); }
    button:focus-visible, input:focus-visible, select:focus-visible, textarea:focus-visible, a:focus-visible { outline: none; box-shadow: 0 0 0 3px color-mix(in oklab, var(--accent), transparent 70%); border-radius: var(--radius-sm); }

    .app { display: flex; flex-direction: column; height: 100vh; overflow: hidden; }

    /* ── Top Nav ── */
    .topnav { display: flex; align-items: center; gap: var(--space-4); padding: 0 var(--space-6); height: 56px; background: var(--surface); border-bottom: 1px solid var(--border); flex-shrink: 0; }
    .topnav-brand { display: flex; align-items: center; gap: var(--space-2); font-size: var(--text-base); font-weight: 600; color: var(--fg); text-decoration: none; }
    .topnav-brand:hover { text-decoration: none; }
    .topnav-logo { width: 28px; height: 28px; background: var(--accent); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .topnav-logo svg { color: white; }
    .topnav-divider { width: 1px; height: 20px; background: var(--border); flex-shrink: 0; }
    .topnav-project { font-size: var(--text-sm); color: var(--muted); }
    .topnav-spacer { flex: 1; }
    .nav-pill { display: flex; gap: var(--space-1); background: var(--bg); border-radius: var(--radius-sm); padding: 3px; }
    .nav-pill-btn { padding: 5px 14px; font-size: var(--text-sm); font-weight: 500; color: var(--muted); border-radius: 5px; transition: all var(--motion-fast) var(--ease-standard); white-space: nowrap; }
    .nav-pill-btn:hover { background: var(--surface); color: var(--fg); }
    .nav-pill-btn.active { background: var(--accent); color: var(--accent-on); }
    .topnav-avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--accent); color: white; display: flex; align-items: center; justify-content: center; font-size: var(--text-sm); font-weight: 600; flex-shrink: 0; }

    /* ── Filter Bar ── */
    .filter-bar { display: flex; align-items: center; gap: var(--space-4); padding: var(--space-3) var(--space-6); background: var(--surface); border-bottom: 1px solid var(--border); flex-shrink: 0; }
    .filter-pills { display: flex; gap: var(--space-2); }
    .filter-pill { padding: 4px 12px; font-size: var(--text-sm); font-weight: 500; border-radius: 999px; border: 1px solid var(--border); color: var(--muted); background: var(--surface); transition: all var(--motion-fast) var(--ease-standard); cursor: pointer; }
    .filter-pill:hover { border-color: var(--accent); color: var(--accent); }
    .filter-pill.active { background: var(--accent); border-color: var(--accent); color: var(--accent-on); }
    .filter-spacer { flex: 1; }
    .filter-count { font-size: var(--text-sm); color: var(--muted); white-space: nowrap; }
    .search-wrap { position: relative; display: flex; align-items: center; }
    .search-icon { position: absolute; left: 10px; color: var(--muted); pointer-events: none; display: flex; }
    .search-icon svg { width: 14px; height: 14px; }
    .search-input { padding: 6px 10px 6px 32px; font-size: var(--text-sm); border: 1px solid var(--border); border-radius: var(--radius-sm); background: var(--bg); color: var(--fg); width: 180px; transition: all var(--motion-fast) var(--ease-standard); outline: none; }
    .search-input::placeholder { color: var(--meta); }
    .search-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(47,111,235,0.10); width: 220px; }
    .search-clear { position: absolute; right: 8px; width: 18px; height: 18px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--muted); cursor: pointer; transition: all var(--motion-fast); }
    .search-clear:hover { background: var(--bg); color: var(--fg); }
    .search-clear svg { width: 10px; height: 10px; }
    .btn { display: inline-flex; align-items: center; gap: var(--space-2); padding: 7px 14px; font-size: var(--text-sm); font-weight: 500; border-radius: var(--radius-sm); transition: all var(--motion-fast) var(--ease-standard); white-space: nowrap; }
    .btn-primary { background: var(--accent); color: var(--accent-on); }
    .btn-primary:hover { background: var(--accent-hover); }
    .btn-secondary { border: 1px solid var(--border); color: var(--fg); background: var(--surface); }
    .btn-secondary:hover { border-color: var(--accent); color: var(--accent); }
    .btn-ghost { color: var(--muted); padding: 6px 10px; }
    .btn-ghost:hover { background: var(--bg); color: var(--fg); }
    .btn svg { width: 14px; height: 14px; flex-shrink: 0; }

    /* ── Kanban Board ── */
    .kanban-wrap { display: flex; flex: 1; overflow: hidden; }
    .kanban-board { display: flex; gap: var(--space-4); padding: var(--space-5) var(--space-6); overflow-x: auto; overflow-y: hidden; align-items: flex-start; flex: 1; min-height: 0; }
    .kanban-board > * { flex-shrink: 0; }

    .kcol { width: 300px; background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius-md); display: flex; flex-direction: column; max-height: calc(100vh - 130px); transition: border-color var(--motion-fast) var(--ease-standard), box-shadow var(--motion-fast) var(--ease-standard); }
    .kcol.drop-target { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(47,111,235,0.15); }
    .kcol-head { display: flex; align-items: center; gap: var(--space-2); padding: var(--space-3) var(--space-4); border-bottom: 1px solid var(--border); flex-shrink: 0; }
    .kcol-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .kcol-title { font-size: var(--text-sm); font-weight: 600; flex: 1; }
    .kcol-count { font-size: 11px; font-weight: 600; color: var(--muted); background: var(--surface); border: 1px solid var(--border); border-radius: 999px; padding: 1px 7px; font-variant-numeric: tabular-nums; }
    .kcol-body { padding: var(--space-3); display: flex; flex-direction: column; gap: var(--space-2); overflow-y: auto; flex: 1; min-height: 0; }
    .kcol-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: var(--space-8) var(--space-4); color: var(--meta); font-size: var(--text-sm); text-align: center; }
    .kcol-empty-icon { width: 32px; height: 32px; margin-bottom: var(--space-2); color: var(--border); }
    .kcol-footer { padding: var(--space-2) var(--space-3); border-top: 1px solid var(--border); flex-shrink: 0; }
    .add-card-btn { display: flex; align-items: center; gap: var(--space-2); color: var(--muted); font-size: var(--text-sm); padding: var(--space-2) var(--space-2); border-radius: var(--radius-sm); width: 100%; transition: all var(--motion-fast) var(--ease-standard); }
    .add-card-btn:hover { background: var(--surface); color: var(--accent); }
    .add-card-btn svg { width: 14px; height: 14px; flex-shrink: 0; }

    /* ── Task Card ── */
    .task-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-md); padding: var(--space-3) var(--space-4); cursor: grab; transition: box-shadow var(--motion-fast) var(--ease-standard), transform var(--motion-fast) var(--ease-standard), opacity var(--motion-fast) var(--ease-standard), border-color var(--motion-fast) var(--ease-standard); user-select: none; }
    .task-card:hover { box-shadow: var(--elev-raised); transform: translateY(-1px); border-color: color-mix(in oklab, var(--border), var(--fg) 15%); }
    .task-card.dragging { opacity: 0.45; transform: rotate(1.5deg); box-shadow: var(--elev-raised); }
    .task-card.drag-over { border-color: var(--accent); }
    .card-top { display: flex; align-items: flex-start; gap: var(--space-2); margin-bottom: var(--space-2); }
    .priority-dot { width: 7px; height: 7px; border-radius: 50%; margin-top: 5px; flex-shrink: 0; }
    .card-title { font-size: var(--text-sm); font-weight: 600; color: var(--fg); flex: 1; line-height: 1.4; }
    .card-body { margin-bottom: var(--space-2); }
    .card-desc { font-size: var(--text-xs); color: var(--muted); line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .card-tags { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: var(--space-2); }
    .tag { font-size: 10px; font-weight: 600; padding: 2px 7px; border-radius: 4px; white-space: nowrap; }
    .tag-jiafang { background: #dbeafe; color: #1d4ed8; }
    .tag-internal { background: var(--bg); color: var(--muted); border: 1px solid var(--border); }
    .tag-requester { background: #fef9c3; color: #854d0e; }
    .card-footer { display: flex; align-items: center; justify-content: space-between; padding-top: var(--space-2); border-top: 1px solid var(--border-soft); }
    .card-meta { display: flex; align-items: center; gap: var(--space-3); }
    .card-meta-item { display: flex; align-items: center; gap: 3px; font-size: 11px; color: var(--muted); }
    .card-meta-item svg { width: 11px; height: 11px; }
    .card-assignee { width: 24px; height: 24px; border-radius: 50%; background: var(--accent); color: white; font-size: 10px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; border: 2px solid var(--surface); }

    /* ── Modal ── */
    .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.35); display: flex; align-items: center; justify-content: center; z-index: 1000; padding: var(--space-4); }
    .modal { background: var(--surface); border-radius: var(--radius-lg); width: 100%; max-width: 520px; max-height: 90vh; overflow-y: auto; box-shadow: 0 8px 32px rgba(0,0,0,0.12); }
    .modal-head { display: flex; align-items: center; justify-content: space-between; padding: var(--space-5) var(--space-6); border-bottom: 1px solid var(--border); }
    .modal-title { font-size: var(--text-lg); font-weight: 700; }
    .modal-close { width: 32px; height: 32px; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; color: var(--muted); transition: all var(--motion-fast) var(--ease-standard); }
    .modal-close:hover { background: var(--bg); color: var(--fg); }
    .modal-body { padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-4); }
    .form-row { display: flex; flex-direction: column; gap: var(--space-2); }
    .form-label { font-size: var(--text-sm); font-weight: 600; color: var(--fg); }
    .form-hint { font-size: var(--text-xs); color: var(--muted); }
    .form-input { width: 100%; padding: 8px 12px; border: 1px solid var(--border); border-radius: var(--radius-sm); font-size: var(--text-sm); color: var(--fg); background: var(--surface); transition: border-color var(--motion-fast) var(--ease-standard); outline: none; }
    .form-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(47,111,235,0.12); }
    textarea.form-input { resize: vertical; min-height: 80px; }
    select.form-input { cursor: pointer; }
    .form-row-inline { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3); }
    .modal-foot { display: flex; gap: var(--space-3); justify-content: flex-end; padding: var(--space-4) var(--space-6); border-top: 1px solid var(--border); }
    .tag-select { display: flex; flex-wrap: wrap; gap: var(--space-2); padding: var(--space-3); border: 1px solid var(--border); border-radius: var(--radius-sm); background: var(--surface); }
    .tag-option { display: flex; align-items: center; gap: var(--space-2); padding: 4px 10px; border-radius: 999px; font-size: var(--text-sm); border: 1px solid var(--border); cursor: pointer; transition: all var(--motion-fast) var(--ease-standard); }
    .tag-option:hover { border-color: var(--accent); color: var(--accent); }
    .tag-option.selected { background: var(--accent); border-color: var(--accent); color: var(--accent-on); }
    .assignee-grid { display: flex; flex-wrap: wrap; gap: var(--space-2); }
    .assignee-chip { display: flex; align-items: center; gap: 6px; padding: 5px 10px; border-radius: 999px; font-size: var(--text-sm); border: 1px solid var(--border); cursor: pointer; transition: all var(--motion-fast) var(--ease-standard); background: var(--surface); }
    .assignee-chip:hover { border-color: var(--accent); }
    .assignee-chip.selected { background: var(--accent); border-color: var(--accent); color: var(--accent-on); }

    /* ── Dashboard ── */
    .dashboard { padding: var(--space-6); overflow-y: auto; flex: 1; }
    .db-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: var(--space-6); }
    .db-title { font-size: var(--text-2xl); font-weight: 700; letter-spacing: var(--tracking-display); margin-bottom: 4px; }
    .db-sub { font-size: var(--text-sm); color: var(--muted); }
    .db-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-4); margin-bottom: var(--space-6); }
    .stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-md); padding: var(--space-5); position: relative; overflow: hidden; }
    .stat-card::before { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 3px; }
    .stat-card:nth-child(1)::before { background: var(--muted); }
    .stat-card:nth-child(2)::before { background: var(--accent); }
    .stat-card:nth-child(3)::before { background: var(--warn); }
    .stat-card:nth-child(4)::before { background: var(--success); }
    .stat-label { font-size: var(--text-xs); color: var(--muted); font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-2); }
    .stat-value { font-size: 40px; font-weight: 700; letter-spacing: -0.02em; line-height: 1; font-variant-numeric: tabular-nums; }
    .stat-change { font-size: var(--text-xs); margin-top: var(--space-2); }
    .stat-change.up { color: var(--success); }
    .stat-change.neutral { color: var(--muted); }
    .stat-change.warn { color: var(--danger); }
    .db-progress-section { margin-bottom: var(--space-5); }
    .progress-row { display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-3); }
    .progress-label { font-size: var(--text-sm); font-weight: 500; width: 80px; flex-shrink: 0; }
    .progress-track { flex: 1; height: 8px; background: var(--bg); border-radius: 999px; overflow: hidden; }
    .progress-fill { height: 100%; border-radius: 999px; transition: width 0.4s var(--ease-standard); }
    .progress-pct { font-size: var(--text-xs); font-variant-numeric: tabular-nums; color: var(--muted); width: 36px; text-align: right; flex-shrink: 0; }
    .db-grid { display: grid; grid-template-columns: 1fr 340px; gap: var(--space-5); }
    .db-section { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-md); overflow: hidden; }
    .db-sec-head { display: flex; align-items: center; justify-content: space-between; padding: var(--space-4) var(--space-5); border-bottom: 1px solid var(--border); }
    .db-sec-title { font-size: var(--text-sm); font-weight: 700; }
    .db-sec-body { padding: 0; }
    .task-table { width: 100%; border-collapse: collapse; }
    .task-table th { font-size: 11px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; padding: var(--space-3) var(--space-4); text-align: left; border-bottom: 1px solid var(--border); background: var(--bg); }
    .task-table td { padding: var(--space-3) var(--space-4); font-size: var(--text-sm); border-bottom: 1px solid var(--border-soft); vertical-align: middle; }
    .task-table tr:last-child td { border-bottom: none; }
    .task-table tr:hover td { background: var(--bg); }
    .td-title { font-weight: 500; max-width: 240px; }
    .td-title-inner { display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
    .status-dot { width: 7px; height: 7px; border-radius: 50%; display: inline-block; margin-right: 6px; flex-shrink: 0; }
    .priority-badge { font-size: 10px; font-weight: 600; padding: 2px 7px; border-radius: 4px; }
    .pb-high { background: var(--danger-bg); color: var(--danger); }
    .pb-medium { background: var(--warn-bg); color: #854d0e; }
    .pb-low { background: var(--success-bg); color: var(--success); }
    .source-badge { font-size: 10px; font-weight: 600; padding: 2px 7px; border-radius: 4px; }
    .sb-jiafang { background: #dbeafe; color: #1d4ed8; }
    .sb-internal { background: var(--bg); color: var(--muted); border: 1px solid var(--border); }
    .sb-requester { background: #fef9c3; color: #854d0e; }
    .assignee-mini { width: 22px; height: 22px; border-radius: 50%; background: var(--accent); color: white; font-size: 10px; font-weight: 700; display: flex; align-items: center; justify-content: center; }
    .no-data { padding: var(--space-8); text-align: center; color: var(--muted); font-size: var(--text-sm); }
    .export-bar { display: flex; flex-direction: column; gap: var(--space-3); padding: var(--space-4) var(--space-5); }
    .export-title { font-size: var(--text-sm); font-weight: 700; }
    .export-desc { font-size: var(--text-xs); color: var(--muted); line-height: 1.5; }
    .export-btn { display: flex; align-items: center; gap: var(--space-2); padding: 8px 14px; background: var(--accent); color: var(--accent-on); border-radius: var(--radius-sm); font-size: var(--text-sm); font-weight: 500; transition: background var(--motion-fast) var(--ease-standard); }
    .export-btn:hover { background: var(--accent-hover); }
    .export-btn svg { width: 14px; height: 14px; }

    /* ── Color dots per column ── */
    .dot-todo { background: var(--meta); }
    .dot-inprogress { background: var(--accent); }
    .dot-review { background: var(--warn); }
    .dot-blocked { background: var(--danger); }
    .dot-done { background: var(--success); }

    /* ── Responsive ── */
    @media (max-width: 1200px) {
      .db-stats { grid-template-columns: repeat(2, 1fr); }
      .kcol { width: 260px; }
    }
    @media (max-width: 900px) {
      .db-grid { grid-template-columns: 1fr; }
      .form-row-inline { grid-template-columns: 1fr; }
      .filter-bar { flex-wrap: wrap; }
      .topnav-project, .topnav-divider { display: none; }
      .kcol { width: 240px; }
    }
    @media (max-width: 640px) {
      .db-stats { grid-template-columns: 1fr; }
      .stat-value { font-size: 32px; }
      .kcol { width: 220px; }
    }
  </style>
</head>
<body>
<div id="root"></div>
<script type="text/babel">
const { useState, useEffect, useRef, useCallback, useMemo } = React;

/* ═══════════════════════════════════════════
   DATA STORE (simulated — swap for API)
═══════════════════════════════════════════ */
const TEAM_MEMBERS = ["张三", "李四", "王五", "赵六", "钱七", "孙八"];
const JIAFANG_SOURCES = ["需求对接人", "项目对接人"];

const INITIAL_TASKS = [
